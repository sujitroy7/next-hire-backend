// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  ORGANIZATION
  RECRUITER
  CANDIDATE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACTUAL
}

enum WorkplaceType {
  REMOTE
  HYBRID
  ON_SITE
}

enum ExperienceLevel {
  UNDER_1_YEAR
  YEARS_1_TO_2
  YEARS_2_TO_3
  YEARS_3_TO_5
  YEARS_5_TO_10
  YEARS_10_PLUS
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum SalaryInterval {
  HOURLY
  MONTHLY
  YEARLY
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

enum OrganizationType {
  TECHNOLOGY
  FINANCE
  HEALTHCARE
  EDUCATION
  RETAIL
  MANUFACTURING
  GOVERMENT
  NON_PROFIT
  OTHER
}

enum EmployeeCountEnum {
  RANGE_1_10
  RANGE_11_50
  RANGE_51_200
  RANGE_201_500
  RANGE_501_PLUS
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?
  passwordHash String
  userType     UserType @default(CANDIDATE)
  createdAt    DateTime @default(now())
  addressId    String?  @unique

  organizationProfile OrganizationProfile?
  recruiterProfile    RecruiterProfile?    @relation("RecruiterUser")
  candidateProfile    CandidateProfile?
  address             Address?             @relation(fields: [addressId], references: [id])

  organizationRecruiters RecruiterProfile[] @relation("RecruiterOrganization")
  jobsAsOrganization     Job[]              @relation("JobRecruiter")
  jobsAsRecruiter        Job[]              @relation("JobOrganization")
  refreshTokens          RefreshToken[]
}

model OrganizationProfile {
  id               String             @id @default(uuid())
  userId           String             @unique
  name             String
  about            String?
  isActive         Boolean            @default(true)
  isVerified       Boolean            @default(false)
  organizationType OrganizationType?
  employeeCount    EmployeeCountEnum?

  logoUrl       String?
  galleryImages String[]

  publicEmail String?
  publicPhone String?
  websiteUrl  String?
  linkedinUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model RecruiterProfile {
  id             String @id @default(uuid())
  userId         String @unique
  organizationId String
  firstName      String
  lastName       String

  publicEmail String?
  publicPhone String?
  linkedinUrl String?
  about       String?

  isActive Boolean @default(true)

  // relation with user-table
  user User @relation("RecruiterUser", fields: [userId], references: [id])

  organization User? @relation("RecruiterOrganization", fields: [organizationId], references: [id])
}

model CandidateProfile {
  id        String @id @default(uuid())
  userId    String @unique
  firstName String
  lastName  String

  headline    String?
  bio         String?
  publicPhone String?
  publicEmail String?
  linkedinUrl String?
  websiteUrl  String?
  resumeUrl   String?

  isActive     Boolean @default(true)
  isVerified   Boolean @default(true)
  isOpenToWork Boolean @default(true)

  experiences CandidateExperience[]

  // relation with user-table
  user User @relation(fields: [userId], references: [id])

  jobApplications JobApplication[]
}

model CandidateExperience {
  id                 String @id @default(uuid())
  candidateProfileId String

  companyName    String
  jobTitle       String
  employmentType EmploymentType @default(FULL_TIME)
  description    String?
  location       String?

  startDate DateTime
  endDate   DateTime?

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id String @id @default(uuid())

  country     String
  state       String
  city        String
  postalCode  String?
  streetLine1 String?
  streetLine2 String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User?
}

model Job {
  id             String @id @default(uuid())
  organizationId String
  recruiterId    String

  title         String
  description   String
  department    String?
  location      String?
  workplaceType WorkplaceType @default(ON_SITE)

  employmentType  EmploymentType
  experienceLevel ExperienceLevel?

  // Salary
  currency       String?         @default("USD")
  salaryMin      Int?
  salaryMax      Int?
  salaryInterval SalaryInterval?

  // Application
  skills           String[]
  vacancies        Int?     @default(1)
  externalApplyUrl String?

  // Status & Lifecycle
  status      JobStatus @default(DRAFT)
  isActive    Boolean   @default(true) // retained for simple toggling if needed
  publishedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    User?            @relation("JobOrganization", fields: [organizationId], references: [id])
  recruiter       User?            @relation("JobRecruiter", fields: [recruiterId], references: [id])
  jobApplications JobApplication[]

  search_vector Unsupported("tsvector")?

  @@index([search_vector], type: Gin)
}

model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  candidateId String
  resumeUrl   String
  status      ApplicationStatus @default(APPLIED)
  appliedAt   DateTime          @default(now())

  job       Job              @relation(fields: [jobId], references: [id])
  candidate CandidateProfile @relation(fields: [candidateId], references: [id])

  @@unique([jobId, candidateId])
}

model RefreshToken {
  id        String @id @default(cuid())
  tokenHash String @unique
  userId    String

  device    String?
  ipAddress String?

  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
